# ============================================
# AI Hub 后端 - 本地开发环境变量
# ============================================
# 使用方式：
#   cp backend/.env.example backend/.env
#   然后编辑 backend/.env 填写你的配置
# ============================================

# 数据库配置
DB_USERNAME=root
DB_PASSWORD=your_database_password

# JWT 签名密钥（至少 64 字符）
JWT_SECRET=your_jwt_secret_at_least_64_characters_long_for_hs512_algorithm

# AI API Key（DeepSeek）
AI_API_KEY=sk-your-api-key-here

# 阿里云 OSS 配置（可选）
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET_NAME=
ALIYUN_OSS_DOMAIN=
