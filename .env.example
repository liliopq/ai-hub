# ============================================
# AI Hub 环境变量配置模板
# ============================================
# 使用方式：
#   cp .env.example .env    （复制并编辑）
#   docker compose up -d --build
#
# 本地开发也可以使用：
#   cp .env.example backend/.env  （后端开发模式）
# ============================================

# 数据库密码（MySQL root 密码）
DB_PASSWORD=Root@123456

# 数据库名称
DB_NAME=ai_hub

# Redis 密码（留空则无密码认证，生产环境建议设置）
REDIS_PASSWORD=

# JWT 签名密钥（必须 ≥ 64 字符，生产环境请修改！）
# 生成方式：openssl rand -base64 64
JWT_SECRET=aihub_community_jwt_secret_key_must_be_at_least_64_characters_long_for_hs512_algorithm

# AI API Key（DeepSeek）
# 获取地址：https://platform.deepseek.com/
AI_API_KEY=sk-your-api-key-here

# 阿里云 OSS 配置（可选，不配置则使用本地存储）
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET_NAME=
ALIYUN_OSS_DOMAIN=

# CORS 允许的域名（Nginx 反代后的前端地址）
CORS_ORIGINS=http://localhost

# RabbitMQ 配置（消息队列，用于通知异步化）
# 生产环境请修改默认账号密码
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
